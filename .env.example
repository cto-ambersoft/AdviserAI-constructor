APP_NAME=Trade Platform API
API_V1_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trade_platform
POSTGRES_USER=trade_user
POSTGRES_PASSWORD=trade_password

REDIS_URL=redis://localhost:6379/0

# SECURITY: in production (DEBUG=false) the app refuses to start while these hold
# the placeholder values below or are shorter than 32 chars. Generate strong values:
#   SECRET_KEY / JWT_SECRET_KEY : python -c "import secrets; print(secrets.token_urlsafe(48))"
#   ENCRYPTION_KEY (Fernet)     : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=change_me_to_random_secret
# Dev-only default below is a valid Fernet key but is public (in source) — prod rejects it.
ENCRYPTION_KEY=ZGV2LWluc2VjdXJlLWRlZmF1bHQtZmVybmV0LWtleSE=
# Rotation/migration only: old raw ENCRYPTION_KEY value(s), comma-separated, so
# pre-rotation ciphertext stays decryptable. Leave empty in steady state.
ENCRYPTION_KEY_LEGACY=
JWT_SECRET_KEY=change_me_to_random_jwt_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Login throttle (per source IP and per email) — fixed window.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
# When true, step-up-gated critical actions require 2FA (no-2FA users are refused).
STEP_UP_REQUIRE_2FA=false
# Cooldown (s) between acting on repeated in-position watcher triggers (0 disables).
WATCHER_TRIGGER_COOLDOWN_SECONDS=300

# CORS: set explicit origins in production (wildcard warns at startup when DEBUG=false).
# JSON list, e.g. CORS_ALLOW_ORIGINS=["https://app.example.com"]
CORS_ALLOW_ORIGINS=["*"]

EXCHANGE_HTTP_TIMEOUT_SECONDS=10
EXCHANGE_MAX_RETRIES=3
EXCHANGE_RETRY_DELAY_MS=700
EXCHANGE_DEFAULT_PAGE_LIMIT=100

ANALYSIS_BACKEND_BASE_URL=http://localhost:3001
ANALYSIS_BACKEND_API_KEY=
ANALYSIS_HTTP_TIMEOUT_SECONDS=15
TASKIQ_STREAM_MAXLEN=10000
TASKIQ_RESULT_KEEP_RESULTS=false
TASKIQ_RESULT_EX_TIME_SECONDS=1800
TASKIQ_RESULT_KEY_PREFIX=taskiq:result
PERSONAL_ANALYSIS_STATUS_BATCH_SIZE=100
PERSONAL_ANALYSIS_MAX_ATTEMPTS=3
PERSONAL_ANALYSIS_POLL_INTERVAL_SECONDS=60
PERSONAL_ANALYSIS_SCHEDULER_LOOP_ENABLED=true
AUTO_TRADE_STATUS_BATCH_SIZE=100
AUTO_TRADE_MAX_ATTEMPTS=5
AUTO_TRADE_RETRY_INTERVAL_SECONDS=60
AUTO_TRADE_SCHEDULER_LOOP_ENABLED=true

# Telegram trade notifications (leave TELEGRAM_BOT_TOKEN empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_LINK_CODE_TTL_SECONDS=900
TELEGRAM_NOTIFY_BATCH_SIZE=200
TELEGRAM_NOTIFY_MAX_ATTEMPTS=5
TELEGRAM_NOTIFY_LOOKBACK_MINUTES=30
TELEGRAM_HTTP_TIMEOUT_SECONDS=10

# Email confirmation for critical actions (T20). Empty RESEND_API_KEY/EMAIL_FROM
# disables the feature (endpoints report "not configured"). EMAIL_FROM must be on a
# Resend-verified domain.
RESEND_API_KEY=
EMAIL_FROM=
RESEND_BASE_URL=https://api.resend.com
EMAIL_HTTP_TIMEOUT_SECONDS=10
EMAIL_CONFIRM_CODE_TTL_MINUTES=10
